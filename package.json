{
  "name": "jdr-compagnon",
  "version": "1.0.0",
  "description": "Compagnon de jeu de rôle auto-hébergé : dés, fiches de personnages, combat et synchronisation temps réel. Sans thème figé, 100% local et gratuit.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.client.json",
    "start": "npm run build && node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "express": "^4.19.2",
    "socket.io": "^4.7.5",
    "typescript": "^5.5.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "dotenv": "^16.4.5"
  }
}
